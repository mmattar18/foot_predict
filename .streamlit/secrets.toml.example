# Modèle de secrets pour Streamlit Community Cloud.
#
# EN LOCAL  : tu n'as PAS besoin de ce fichier — l'app lit déjà ton .env.
# SUR LE CLOUD : ne committe JAMAIS le vrai secrets.toml. Copie ce contenu
#   dans Streamlit Cloud → ton app → "Settings" → "Secrets", en remplaçant
#   les valeurs. (Le vrai .streamlit/secrets.toml est ignoré par git.)

# Mot de passe d'accès à l'application (protège ton quota d'API).
APP_PASSWORD = "choisis-un-mot-de-passe-solide"

# LLM — Groq (gratuit) : https://console.groq.com/keys
GROQ_API_KEY = "gsk_xxx"
GROQ_MODEL = "llama-3.1-8b-instant"

# Données réelles — football-data.org (gratuit) :
# https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY = "xxx"
FOOTBALL_DATA_COMPETITIONS = "WC,PL,PD,SA,BL1,FL1,DED,PPL,ELC"
