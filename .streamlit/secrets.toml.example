# Secrets template for Streamlit Community Cloud.
#
# LOCALLY  : you do NOT need this file — the app already reads your .env.
# ON CLOUD : never commit the real secrets.toml. Paste this content into
#   Streamlit Cloud → your app → "Settings" → "Secrets", replacing the values.
#   (The real .streamlit/secrets.toml is git-ignored.)

# OPTIONAL password gate — omit this line entirely for an open (no-password) app.
# APP_PASSWORD = "choose-a-strong-password"

# Daily cap on real predictions to protect your API quota (no password needed).
# Repeats of the same matchup are cached and free. 0 = no cap.
DAILY_PREDICTION_LIMIT = "50"

# LLM — Groq (free): https://console.groq.com/keys
GROQ_API_KEY = "gsk_xxx"
GROQ_MODEL = "llama-3.1-8b-instant"

# Real data — football-data.org (free):
# https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY = "xxx"
FOOTBALL_DATA_COMPETITIONS = "WC,PL,PD,SA,BL1,FL1,DED,PPL,ELC"
