# ── Web app access (Streamlit) ───────────────────────────────────────────
# Shareable password that protects your API quota in deployment.
# Leave empty locally for password-free access.
APP_PASSWORD=

# ── LLM: Groq API (free) ─────────────────────────────────────────────────
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
# (Optional) Groq model. Default: llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant

# ── Data source ──────────────────────────────────────────────────────────
# auto (default): real API if FOOTBALL_DATA_API_KEY is set, otherwise mock
# mock          : always simulated data (offline)
# football-data : always the real API
DATA_SOURCE=auto

# ── Real data: football-data.org API (free) ──────────────────────────────
# Sign up + free key: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
# (Optional) competitions scanned to resolve a team by name.
# football-data codes: WC=World Cup, PL=Premier League, PD=La Liga,
# SA=Serie A, BL1=Bundesliga, FL1=Ligue 1, DED=Eredivisie, PPL=Primeira Liga,
# ELC=Championship.
FOOTBALL_DATA_COMPETITIONS=WC,PL,PD,SA,BL1,FL1,DED,PPL,ELC
