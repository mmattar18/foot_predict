# ── Accès à l'app web (Streamlit) ────────────────────────────────────────
# Mot de passe partageable qui protège ton quota d'API en déploiement.
# Laisse vide en local pour un accès sans mot de passe.
APP_PASSWORD=

# ── LLM : API Groq (gratuite) ────────────────────────────────────────────
# Obtenez une clé sur https://console.groq.com/keys
GROQ_API_KEY=gsk_votre_cle_ici
# (Optionnel) modèle Groq. Par défaut : llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant

# ── Source de données ────────────────────────────────────────────────────
# auto (défaut) : API réelle si FOOTBALL_DATA_API_KEY présente, sinon mock
# mock          : toujours les données simulées (hors-ligne)
# football-data : toujours l'API réelle
DATA_SOURCE=auto

# ── Données réelles : API football-data.org (gratuite) ───────────────────
# Inscription + clé gratuite : https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
# (Optionnel) compétitions scannées pour retrouver une équipe par son nom.
# Codes football-data : WC=Coupe du Monde, PL=Premier League, PD=Liga,
# SA=Serie A, BL1=Bundesliga, FL1=Ligue 1, DED=Eredivisie, PPL=Primeira Liga,
# ELC=Championship.
FOOTBALL_DATA_COMPETITIONS=WC,PL,PD,SA,BL1,FL1,DED,PPL,ELC
